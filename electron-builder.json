{
  "appId": "com.joanium.app",
  "productName": "Joanium",
  "copyright": "Copyright © 2026 Joel Jolly",
  "asar": true,
  "afterSign": "Scripts/Fuses.cjs",
  "files": [
    "App.js",
    "Assets/**/*",
    "Config/**/*",
    "Datasets/**/*",
    "Packages/**/*",
    "!Packages/**/__tests__/**",
    "Prompts/**/*"
  ],
  "extraResources": [
    {
      "from": "Data",
      "to": "Data",
      "filter": [
        "**/*",
        "!Agents/**",
        "!Channels/**",
        "!Projects/**",
        "!Templates/**",
        "!Chats/**",
        "!ChannelMessages/**",
        "!Memories/**",
        "!ModelCache/**",
        "!Models/**",
        "!Logs/**",
        "!Screenshots/**",
        "!Avatar.*",
        "!User.json",
        "!Usage/**",
        "!Channels.json",
        "!MCPServers.json",
        "!Security.json",
        "!System.json"
      ]
    },
    {
      "from": "Skills",
      "to": "Skills",
      "filter": ["**/*.md"]
    },
    {
      "from": "Personas",
      "to": "Personas",
      "filter": ["**/*.md"]
    }
  ],
  "directories": {
    "output": "dist"
  },
  "publish": {
    "provider": "github",
    "owner": "Joanium",
    "repo": "Joanium",
    "releaseType": "release"
  },
  "win": {
    "target": "nsis",
    "icon": "Assets/Logo/Logo.ico",
    "artifactName": "Joanium.exe"
  },
  "mac": {
    "target": "dmg",
    "icon": "Assets/Logo/Logo.icns",
    "category": "public.app-category.productivity",
    "artifactName": "Joanium.dmg"
  },
  "linux": {
    "target": "AppImage",
    "icon": "Assets/Logo/Logo.png",
    "category": "Utility",
    "artifactName": "Joanium.AppImage"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "Assets/Logo/Logo.ico",
    "uninstallerIcon": "Assets/Logo/Logo.ico"
  }
}
