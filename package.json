{
  "name": "Joanium",
  "version": "2026.520.0",
  "description": "Local-first AI desktop assistant with multi-model chat, automations, agents, MCP, and real integrations. Works with Anthropic, OpenAI, Gemini, Ollama and more.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "electron-updater": "6.8.3",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.1",
    "electron": "42.0.1",
    "electron-builder": "^26.10.0",
    "eslint": "10.4.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "9.1.7",
    "jscpd": "4.0.5",
    "lint-staged": "17.0.5",
    "markdownlint-cli": "0.44.0",
    "prettier": "3.5.3"
  },
  "overrides": {
    "glob": ">=10.5.0",
    "markdown-it": ">=14.1.1",
    "smol-toml": ">=1.6.1"
  },
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "build": "node Scripts/Build.mjs",
    "lint": "eslint .",
    "lint:md": "markdownlint **/*.md --ignore node_modules --ignore Data --ignore Skills --ignore Personas",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cpd": "jscpd Packages",
    "check:arch": "node Scripts/CheckArch.mjs",
    "check": "npm run lint && npm run format:check && npm run cpd && npm run lint:md && npm run check:arch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint --fix"
    ]
  },
  "keywords": [
    "joanium",
    "ai-assistant",
    "local-first",
    "desktop-app",
    "electron",
    "electron-app",
    "ai-desktop",
    "ai-agent",
    "automation",
    "mcp",
    "model-context-protocol",
    "multi-model",
    "ollama",
    "anthropic",
    "openai",
    "gemini",
    "agentic-ai",
    "productivity",
    "chatbot",
    "ai-workflow",
    "github-integration",
    "gmail-integration",
    "scheduled-agents",
    "personas",
    "skills",
    "offline-ai",
    "privacy-first"
  ],
  "author": "Joel Jolly",
  "license": "SEE LICENSE IN LICENSE.md"
}
