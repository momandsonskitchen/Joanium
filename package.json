{
  "name": "Joanium",
  "version": "2026.509.0",
  "description": "Local-first AI desktop assistant with multi-model chat, automations, agents, MCP, and real integrations. Works with Anthropic, OpenAI, Gemini, Ollama and more.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "electron-updater": "6.8.3",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "42.0.0",
    "electron-builder": "^26.9.1",
    "eslint": "10.3.0"
  },
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "build": "node Scripts/Build.mjs",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.joanium.app",
    "productName": "Joanium",
    "copyright": "Copyright © 2026 Joel Jolly",
    "files": [
      "**/*",
      "!dist/**",
      "!Scripts/**",
      "!.github/**",
      "!Build/**",
      "!**/*.map",
      "!.git/**",
      "!.eslint*",
      "!.editor*",
      "!.gitignore",
      "!.gitattributes",
      "!.npmignore",
      "!.npmrc",
      "!.nvmrc"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "Assets/Icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "Assets/Icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "Assets/Icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "Assets/Icon.ico",
      "uninstallerIcon": "Assets/Icon.ico"
    }
  },
  "keywords": [
    "joanium",
    "ai-assistant",
    "local-first",
    "desktop-app",
    "electron",
    "electron-app",
    "ai-desktop",
    "ai-agent",
    "automation",
    "mcp",
    "model-context-protocol",
    "multi-model",
    "ollama",
    "anthropic",
    "openai",
    "gemini",
    "agentic-ai",
    "productivity",
    "chatbot",
    "ai-workflow",
    "github-integration",
    "gmail-integration",
    "scheduled-agents",
    "personas",
    "skills",
    "offline-ai",
    "privacy-first"
  ],
  "author": "Joel Jolly",
  "license": "Apache-2.0"
}
